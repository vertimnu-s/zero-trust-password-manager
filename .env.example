# Frontend Environment Variables
# Copy this file to .env and fill in values from Terraform output

# API Gateway endpoint (from terraform output: api_gateway_api_endpoint)
# This is where all API requests are sent
VITE_API_URL=https://xyz123abc.execute-api.eu-north-1.amazonaws.com/dev

# Cognito User Pool ID (from terraform output: cognito_user_pool_id)
# This is used by the AWS Cognito SDK for authentication
VITE_COGNITO_USER_POOL_ID=eu-north-1_ABC123XYZ

# Cognito Application Client ID (from terraform output: cognito_client_id)
# This identifies your frontend app within the Cognito User Pool
VITE_COGNITO_CLIENT_ID=1a2b3c4d5e6f7g8h9i0j

# Optional: AWS Region (if needed in future)
# VITE_AWS_REGION=eu-north-1

# How to get these values:
# 1. Run: terraform apply
# 2. Copy the output values shown at the end
# 3. Or run: terraform output to see them again
#
# Example terraform output:
# cognito_user_pool_id = "eu-north-1_ABC123XYZ"
# cognito_client_id = "1a2b3c4d5e6f7g8h9i0j"
# api_gateway_api_endpoint = "https://xyz123abc.execute-api.eu-north-1.amazonaws.com/dev"

# The frontend uses these to:
# - cognito_user_pool_id: Initialize the Cognito User Pool
# - cognito_client_id: Create a Cognito User for authentication
# - api_url: Make API calls to your Lambda functions through API Gateway
