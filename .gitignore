# ============================================
# ENVIRONMENT & SECRETS (NOT .env.example!)
# ============================================
.env
.env.local
.env.*.local
.env.production.local
.aws/credentials
.aws/config

# ============================================
# TERRAFORM - CRITICAL: CONTAINS AWS SECRETS
# ============================================

# Terraform directories (contains provider cache)
terraform/.terraform/
terraform/.terraform.lock.hcl

# Terraform state files (CONTAINS AWS CREDENTIALS - NEVER COMMIT!)
terraform/*.tfstate
terraform/*.tfstate.*
terraform/.tfstate.lock.info

# Terraform plan files
terraform/tfplan
terraform/tfplan.*
terraform/*.tfplan

# Terraform variable overrides
terraform/*.auto.tfvars
terraform/*.auto.tfvars.json

# Crash logs
terraform/crash.log
terraform/crash.*.log

# ============================================
# LAMBDA - COMPILED & ARCHIVED
# ============================================
terraform/lambda-functions/**/*.zip
terraform/lambda-functions/**/*.js.map
terraform/lambda-functions/**/node_modules/
terraform/lambda-functions/**/.DS_Store
/tmp/
*.tmp

# ============================================
# LOCAL PLANNING DOCS (untracked)
# ============================================
*.local.md

# ============================================
# AWS & DEPLOYMENT
# ============================================
.aws/
.awsrc
aws-vault
aws-cli-credentials
*.pem
*.key
*.pub

# ============================================
# OS FILES
# ============================================
Thumbs.db
.AppleDouble
.LSOverride
*~
.~*

# ============================================
# LOCAL DOCUMENTATION (NOT in repo)
# ============================================
docs/
mermaid/

